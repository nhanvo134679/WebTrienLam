@model IEnumerable<WebTrienLam.Models.TrangPhuc>

@{
    ViewData["Title"] = "Triển Lãm Trang Phục Thời Nguyễn";
    var currentSearch = ViewData["CurrentSearch"] as string;
    var currentCategory = ViewData["CurrentCategory"] as string;
    var savedCostumeIds = ViewBag.SavedCostumeIds as HashSet<int> ?? new HashSet<int>();
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<!-- Hero Section -->
<div class="museum-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <span class="hero-tag">⚜ TRIỂN LÃM SỐ HÓA DI SẢN ⚜</span>
        <h1 class="hero-title">VƯƠNG TRIỀU LỘNG LẪY</h1>
        <p class="hero-subtitle">Khám phá vẻ đẹp, điển chế và chiều sâu lịch sử qua trang phục triều đại nhà Nguyễn (1802 - 1945)</p>
        <div class="gold-decor">
            <span class="line"></span>
            <span class="diamond">♦</span>
            <span class="line"></span>
        </div>
    </div>
</div>

<!-- Lọc & Tìm kiếm -->
<div class="exhibition-controls">
    <div class="container-fluid">
        <div class="controls-row">
            <!-- Bộ lọc danh mục kiểu thẻ Tab -->
            <div class="category-tabs">
                <a href="@Url.Action("Index", new { searchQuery = currentSearch })" 
                   class="tab-link @(string.IsNullOrEmpty(currentCategory) ? "active" : "")">
                    Tất Cả Hiện Vật
                </a>
                @foreach (var cat in categories)
                {
                    <a href="@Url.Action("Index", new { category = cat, searchQuery = currentSearch })" 
                       class="tab-link @(currentCategory == cat ? "active" : "")">
                        @cat
                    </a>
                }
            </div>

            <!-- Thanh tìm kiếm cổ điển -->
            <form method="get" asp-action="Index" class="search-form-custom">
                @if (!string.IsNullOrEmpty(currentCategory))
                {
                    <input type="hidden" name="category" value="@currentCategory" />
                }
                <div class="search-box">
                    <input type="text" name="searchQuery" value="@currentSearch" placeholder="Tìm kiếm theo tên trang phục..." />
                    <button type="submit" class="btn-search">🔍 Tìm Kiếm</button>
                    @if (!string.IsNullOrEmpty(currentSearch))
                    {
                        <a href="@Url.Action("Index", new { category = currentCategory })" class="btn-clear-search" title="Xóa tìm kiếm">✕</a>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Danh sách hiện vật trưng bày -->
<div class="exhibition-gallery container-fluid">
    @if (!Model.Any())
    {
        <div class="empty-gallery">
            <span class="empty-icon">⛩</span>
            <h3>Không tìm thấy hiện vật nào phù hợp</h3>
            <p>Vui lòng thử từ khóa tìm kiếm khác hoặc chuyển danh mục hiển thị.</p>
        </div>
    }
    else
    {
        <div class="gallery-grid">
            @foreach (var item in Model)
            {
                bool isSaved = savedCostumeIds.Contains(item.Id);
                
                <div class="gallery-card">
                    <!-- Ảnh hiện vật & hiệu ứng phủ -->
                    <div class="card-image-wrapper">
                        <img src="@item.HinhAnh" alt="@item.TenTrangPhuc" class="card-img" />
                        <div class="image-overlay-hover">
                            <a asp-controller="TrangPhuc" asp-action="Details" asp-route-id="@item.Id" class="btn-details-overlay">Xem Chi Tiết</a>
                        </div>
                        <span class="card-badge">@item.LoaiTrangPhuc</span>
                        
                        <!-- Nút Yêu Thích Nhanh ở góc ảnh -->
                        <button type="button" class="btn-quick-fav @(isSaved ? "saved" : "")" 
                                data-id="@item.Id" title="@(isSaved ? "Bỏ yêu thích" : "Yêu thích")">
                            ♥
                        </button>
                    </div>

                    <!-- Nội dung tóm tắt -->
                    <div class="card-body-custom">
                        <div class="card-meta">
                            <span class="card-era">@item.TrieuDai</span>
                        </div>
                        <h3 class="card-title">
                            <a asp-controller="TrangPhuc" asp-action="Details" asp-route-id="@item.Id">@item.TenTrangPhuc</a>
                        </h3>
                        <p class="card-desc">@item.MoTaNgan</p>
                    </div>

                    <!-- Chân thẻ card -->
                    <div class="card-footer-custom">
                        <a asp-controller="TrangPhuc" asp-action="Details" asp-route-id="@item.Id" class="btn-readmore">
                            Xem thêm <span class="arrow">→</span>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Xử lý nút yêu thích nhanh
            $('.btn-quick-fav').click(function (e) {
                e.preventDefault();
                var btn = $(this);
                var id = btn.data('id');
                
                $.ajax({
                    url: '/Home/ToggleFavorite',
                    type: 'POST',
                    data: { costumeId: id },
                    headers: {
                        "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            if (response.isSaved) {
                                btn.addClass('saved');
                                btn.attr('title', 'Bỏ yêu thích');
                            } else {
                                btn.removeClass('saved');
                                btn.attr('title', 'Yêu thích');
                            }
                        } else {
                            if (response.redirectUrl) {
                                window.location.href = response.redirectUrl;
                            } else {
                                alert("Có lỗi xảy ra: " + response.message);
                            }
                        }
                    },
                    error: function () {
                        alert("Không thể kết nối mạng. Vui lòng thử lại.");
                    }
                });
            });
        });
    </script>
}
